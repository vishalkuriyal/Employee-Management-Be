# Server Configuration
PORT=8001
NODE_ENV=development

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=EmployeeManagement

# JWT Secret (use a strong, random secret in production)
JWT_KEY=your_secure_jwt_secret_key_here

# Frontend Origin & Base URL (for CORS and absolute links)
# Development
BASE_URL=http://localhost:8001
FRONTEND_ORIGIN=http://localhost:8001

# Production (uncomment and update)
# BASE_URL=https://management.techqilla.com
# FRONTEND_ORIGIN=https://management.techqilla.com
# NODE_ENV=production

# Email Configuration (if using nodemailer)
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_specific_password
ADMIN_EMAIL=admin@techqilla.com

# File Upload
UPLOAD_DIR=public/uploads